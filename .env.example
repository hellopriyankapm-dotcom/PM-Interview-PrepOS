# PrepOS environment variables
# Copy this file to .env.local and fill in the values you need.
# All NEXT_PUBLIC_* vars are inlined into the client bundle at build time.

# ----------------------------------------------------------------------
# Self-promo slot (landing + app sidebar)
# ----------------------------------------------------------------------
# Disabled by default. Set to "true" to render the promo card.
NEXT_PUBLIC_PROMO_ENABLED=false

# REQUIRED when enabled. An endpoint that accepts a JSON POST of
# { email: string, source: string } and returns 2xx on success.
#
# Recommended: Formspree (free tier — 50 submissions/month).
#   1. Sign up at https://formspree.io
#   2. Create a new form, copy the form ID (e.g. "xqkrjbdk")
#   3. Set this var to https://formspree.io/f/<form-id>
#
# Other compatible providers (drop-in replacements):
#   - Buttondown:   https://buttondown.email/api/emails/embed-subscribe/<username>
#   - ConvertKit:   https://app.convertkit.com/forms/<form-id>/subscriptions
#   - Custom:       any endpoint you control that accepts the JSON shape above
NEXT_PUBLIC_PROMO_FORM_ENDPOINT=

# Optional copy overrides — defaults are sensible.
# NEXT_PUBLIC_PROMO_TITLE=Pro Pack — coming soon
# NEXT_PUBLIC_PROMO_DESCRIPTION=AI PM interview questions, extra question banks, expert-answer library, premium personas. Get early-access pricing.
# NEXT_PUBLIC_PROMO_CTA_LABEL=Notify me
# NEXT_PUBLIC_PROMO_SUCCESS=Thanks — we’ll email you when Pro launches.
# NEXT_PUBLIC_PROMO_FINEPRINT=No spam. One email at launch, that’s it.

# ----------------------------------------------------------------------
# Aggregate analytics (privacy-friendly, cookie-free, no PII)
# ----------------------------------------------------------------------
# Pick ONE provider. Leave all unset to disable analytics entirely.

# GoatCounter — recommended free tier. Sign up at https://www.goatcounter.com,
# pick a subdomain (e.g. "pmprepos"), set this to that subdomain (no dot, no
# scheme). Loads //gc.zgo.at/count.js and posts to <subdomain>.goatcounter.com.
NEXT_PUBLIC_GOATCOUNTER_DOMAIN=

# Plausible — set the apex you want tracked (e.g. "pmprepos.com").
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Umami self-hosted — set both:
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=
